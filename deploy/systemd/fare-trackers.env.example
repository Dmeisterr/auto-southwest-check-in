# Copy this file to ~/.config/auto-southwest-check-in/fare-trackers.env and edit it locally.
#
# Gmail requires 2-Step Verification plus an app password. Use the app password without spaces.
# This URL sends from and to the same Gmail account. Add &to=other@example.com for another recipient.
AUTO_SOUTHWEST_CHECK_IN_NOTIFICATION_URL="mailtos://gmail.com?user=your.email@gmail.com&pass=your-app-password"

# Uncomment if Chromium is not auto-detected on your Raspberry Pi.
# AUTO_SOUTHWEST_CHECK_IN_BROWSER_PATH="/usr/bin/chromium-browser"
