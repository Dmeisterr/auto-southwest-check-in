    <key>StandardOutPath</key>
    <string>/Users/daniellott2/Documents/GitHub/auto-southwest-check-in/logs/launchd-fare-trackers.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/daniellott2/Documents/GitHub/auto-southwest-check-in/logs/launchd-fare-trackers.err.log</string>
</dict>
</plist>
